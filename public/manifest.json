{
  "manifest_version": 3,
  "name": "AlgoVault",
  "version": "2.0.2",
  "key": "",
  "description": "AI-powered LeetCode-to-GitHub automation. Auto-sync accepted solutions with AI-generated explanations.",
  "permissions": [
    "identity",
    "storage",
    "notifications",
    "alarms",
    "tabs",
    "webNavigation",
    "cookies"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://api.github.com/*",
    "https://github.com/login/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://codeforces.com/*"
      ],
      "js": ["content-loader.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "assets/*"],
      "matches": [
        "https://leetcode.com/*",
        "https://codeforces.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "AlgoVault"
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
