# AlgoVault Environment Variables
# ================================

# GitHub OAuth App Client ID (required)
# Create at: https://github.com/settings/applications/new
# - Application name: AlgoVault
# - Homepage URL: https://github.com/your-username/algovault
# - Authorization callback URL: https://<your-extension-id>.chromiumapp.org/
# - Enable Device Flow: NO (not needed with launchWebAuthFlow)
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# Auth Proxy URL (required)
# Deploy the Cloudflare Worker in /proxy and set the URL here
VITE_AUTH_PROXY_URL=https://your-worker.workers.dev
