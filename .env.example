# AlgoVault Environment Variables
# ================================

# GitHub OAuth App Client ID (required)
# Create at: https://github.com/settings/applications/new
# - Application name: AlgoVault
# - Homepage URL: https://github.com/your-username/algovault
# - Enable Device Flow: YES (check the box)
# - No callback URL needed for Device Flow
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
